# =============================================================================
# DIPLADEURS GIS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to the repository.
# =============================================================================

# --- Application ---
APP_PORT=3000
APP_ENV=development
# APP_ENV=production

# --- Database (PostgreSQL + PostGIS) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dipladeurs
DB_USER=
DB_PASSWORD=

# --- Authentication ---
JWT_SECRET=
JWT_EXPIRATION_HOURS=8
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# --- GeoServer ---
GEOSERVER_URL=http://localhost:8080/geoserver
GEOSERVER_WORKSPACE=dipladeurs
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=

# --- nginx (reference for infra/nginx config) ---
NGINX_SERVER_NAME=visor.tonala.local
NGINX_LISTEN_PORT=80

# --- File uploads ---
UPLOAD_MAX_SIZE_MB=50
UPLOAD_TEMP_DIR=/tmp/dipladeurs-uploads

# --- Logging ---
LOG_LEVEL=info
# LOG_LEVEL=debug
